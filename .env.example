# Example environment variables for collectors
# Copy to .env and fill with real values if you prefer not to hardcode in scripts

# Supabase connection (example values may be present in scripts as defaults)
SUPABASE_URL=https://REDACTED_SUPABASE_REF.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY

# Metro Transit vehicle positions feed (public)
VEHICLE_POSITIONS_URL=https://svc.metrotransit.org/mtgtfs/vehiclepositions.pb

# Comma-separated route ids to treat as 'light rail' (Blue,Green)
LIGHT_RAIL_ROUTES=901,902

# Poll interval in milliseconds (90s default)
POLL_INTERVAL_MS=90000

# If you run a Dallas collector, set DART feed URL here as needed:
# DART_VEHICLE_POSITIONS_URL=https://dart.example/gtfs/vehiclepositions.pb

# Baltimore MTA Light Rail (Swiftly API)
SWIFTLY_KEY=your_swiftly_api_key
